{
  "name": "inpostapi",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "root": "packages/focus-garden",
  "sourceRoot": "packages/focus-garden",
  "projectType": "application",
  "targets": {
    "build": {
      "executor": "nx:run-commands",
      "options": {
        "cwd": "packages/focus-garden",
        "commands": [
          {
            "command": "sh -c '[ -f .env ] || { echo \".env is required. Create it manually, for example from .env.dist.\"; exit 1; }'"
          },
          {
            "command": "docker compose -f docker-compose.yaml -f docker-compose-portfolio.yaml up --build -d"
          },
          {
            "command": "docker compose -f docker-compose.yaml -f docker-compose-portfolio.yaml exec -T php composer install"
          }
        ],
        "parallel": false
      }
    },
    "dev": {
      "executor": "nx:run-commands",
      "options": {
        "cwd": "packages/focus-garden",
        "commands": [
          {
            "command": "sh -c '[ -f .env ] || { echo \".env is required. Create it manually, for example from .env.dist.\"; exit 1; }'"
          },
          {
            "command": "docker compose -f docker-compose.yaml -f docker-compose-portfolio.yaml up -d"
          }
        ],
        "parallel": false
      }
    }
  }
}
